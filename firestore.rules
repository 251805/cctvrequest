rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isOperator() {
      return hasRole('operator');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isOwner(resourceData) {
      return isSignedIn() && resourceData.requesterUid == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isStaffAction() {
      // For updates on existing docs
      return request.resource.data.staffCode in ['cctv2026', 'mgdh1'];
    }

    // --- User Profiles ---
    match /users/{userId} {
      // Allow users to read their own profile
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Allow operators/admins to read any profile
      allow get, list: if isOperator() || isAdmin();
      
      // Allow users to create their own profile on first join
      // We allow standard requester role for Google logins, 
      // and staff roles for our internal staff login utility.
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Allow users to update their own non-role fields
      allow update: if isSignedIn() && request.auth.uid == userId && 
                    (isAdmin() || request.resource.data.role == resource.data.role);
    }

    // --- CCTV Requests ---
    match /requests/{requestId} {
      function isValidRequest(data) {
        return data.status in ['pending', 'reviewing', 'seeking_approval', 'approved', 'denied', 'processing', 'closed', 'denied'];
      }

      // Allow anybody to read and list requests for the live queue and tracking functionality
      allow get: if true;
      allow list: if request.query.limit <= 500;

      // ALLOW PUBLIC CREATION
      allow create: if isValidRequest(request.resource.data) && (
        request.resource.data.status == 'pending'
      );

      allow update: if (isSignedIn() && (
        // Owners (including anonymous) can update their own pending requests
        (isOwner(resource.data) && resource.data.status == 'pending' && isValidRequest(request.resource.data)) ||
        // Operators can update status and remarks
        (isOperator() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'operatorRemarks', 'attendedBy', 'attendedDate', 'updatedAt'])) ||
        // Admins can update everything
        (isAdmin())
      )) || isStaffAction();

      // Allow deletion by authenticated admin or if soft-delete flag has been set by a staff member
      allow delete: if isAdmin() || (resource.data.isDeleted == true);

      // --- Workflow Logs ---
      match /logs/{logId} {
        allow read: if (isSignedIn()) || true; // Relaxed for anonymous/demo
        allow create: if isOperator() || isAdmin() || isStaffAction();
      }
    }
  }
}
